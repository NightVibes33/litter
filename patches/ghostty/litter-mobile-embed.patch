+    pub fn queueWrite(
+        self: *External,
+        _: Allocator,
+        _: *termio.Termio.ThreadData,
+        data: []const u8,
+        linefeed: bool,
+    ) !void {
+        if (!linefeed) {
+            if (data.len > 0) self.write(self.userdata, data.ptr, data.len);
+            return;
+        }
+
+        var i: usize = 0;
+        var buf: [128]u8 = undefined;
+        while (i < data.len) {
+            var len: usize = 0;
+            while (i < data.len and len < buf.len - 1) {
+                const ch = data[i];
+                i += 1;
+                if (ch == '\r') {
+                    buf[len] = '\r';
+                    buf[len + 1] = '\n';
+                    len += 2;
+                } else {
+                    buf[len] = ch;
+                    len += 1;
+                }
+            }
+
+            if (len > 0) self.write(self.userdata, buf[0..len].ptr, len);
+        }
+    }
