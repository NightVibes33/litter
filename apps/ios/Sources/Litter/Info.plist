<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.sigkitten.litter.turn-check</string>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.sigkitten.litter.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>litterauth</string>
			</array>
		</dict>
	</array>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LitterReleaseOwner</key>
	<string>$(LITTER_RELEASE_OWNER)</string>
	<key>LitterReleaseRepo</key>
	<string>$(LITTER_RELEASE_REPO)</string>
	<key>LitterReleaseManifestAssetName</key>
	<string>$(LITTER_RELEASE_MANIFEST_ASSET_NAME)</string>
	<key>LitterReleaseSourceAssetName</key>
	<string>$(LITTER_RELEASE_SOURCE_ASSET_NAME)</string>
	<key>LitterReleaseStableTag</key>
	<string>$(LITTER_RELEASE_STABLE_TAG)</string>
	<key>LitterReleaseTagPrefix</key>
	<string>$(LITTER_RELEASE_TAG_PREFIX)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>tailscale</string>
		<string>sidestore</string>
		<string>altstore</string>
		<string>localdevvpn</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInLocalNetworking</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>100.100.100.100</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>NSBonjourServices</key>
	<array>
		<string>_codex._tcp</string>
		<string>_ssh._tcp</string>
		<string>_litter-pair._tcp</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Codex discovers coding agents and SSH servers on your local network.</string>
	<key>NSCameraUsageDescription</key>
	<string>Litter uses the camera to capture photos for conversations.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Litter uses the microphone for voice-to-text input.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Litter uses Bluetooth to detect when your iPhone is near your paired Mac.</string>
	<key>NSNearbyInteractionUsageDescription</key>
	<string>Litter uses Nearby Interaction to confirm your iPhone and Mac are close before pairing.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>UIAppFonts</key>
	<array>
		<string>BerkeleyMono-Regular.otf</string>
		<string>BerkeleyMono-Bold.otf</string>
		<string>BerkeleyMono-Oblique.otf</string>
		<string>BerkeleyMono-Bold-Oblique.otf</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
				</dict>
			</array>
			<key>CPTemplateApplicationSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>CarPlay</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
